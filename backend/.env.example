# Copia este archivo como ".env" y rellena tus valores reales.
# NUNCA subas el archivo .env a git — solo .env.example.

# Credenciales de Supabase (se obtienen en supabase.com → tu proyecto → Settings → API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Configuración del servidor local
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
